# Core
APP_ENV=dev
DATABASE_PATH=./data/freelans.db
POLL_INTERVAL_SECONDS=5
MIN_SCORE_TO_APPLY=0.45
MAX_LEADS_PER_PLATFORM=40
MAX_PAGES_PER_PLATFORM_SCAN=8
MAX_APPLIES_PER_CYCLE=30
AUTO_APPLY=false
AUTO_APPLY_HOUR_LIMIT=6
AUTO_APPLY_DAY_LIMIT=30

# Telegram
TELEGRAM_BOT_TOKEN=put_your_token_here
TELEGRAM_CHAT_ID=put_your_chat_id_here
TELEGRAM_CONTROL_ENABLED=true
TELEGRAM_CONTROL_POLL_TIMEOUT=20
TELEGRAM_NOTIFY_BATCH_SIZE=8
TELEGRAM_NOTIFY_RETRY_AFTER_SECONDS=45
TELEGRAM_NOTIFY_MAX_ATTEMPTS=200
TELEGRAM_PLATFORM_BURST_LIMIT=12
TELEGRAM_PLATFORM_BURST_WINDOW_MINUTES=10

# LLM
LLM_PROVIDER=openrouter

# OpenRouter (recommended)
OPENROUTER_API_KEY=put_your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=freelans-bot

# Proposal validation before auto-apply
PROPOSAL_VALIDATION_ENABLED=true
PROPOSAL_MIN_CHARS=280
PROPOSAL_MAX_CHARS=2200
PROPOSAL_SIMILARITY_THRESHOLD=0.93
PROPOSAL_SIMILARITY_WINDOW=30
PROPOSAL_BANNED_PHRASES=guaranteed #1,100% guaranteed,предоплата на карту,только сегодня скидка
VALIDATOR_SPIKE_ALERT_ENABLED=true
VALIDATOR_SPIKE_THRESHOLD=10
VALIDATOR_SPIKE_WINDOW_MINUTES=15
VALIDATOR_SHARE_ALERT_ENABLED=true
VALIDATOR_SHARE_ALERT_THRESHOLD=0.35
VALIDATOR_SHARE_ALERT_MIN_ATTEMPTS=8

# OpenAI (optional fallback)
OPENAI_API_KEY=put_your_openai_key_here
OPENAI_MODEL=gpt-4.1-mini

# Matching
TARGET_LANGUAGES=ru
KEYWORDS=python,telegram bot,chatbot,сайт,web app,automation,автоматизация,api integration,парсинг
FOCUS_KEYWORDS=python,fastapi,django,flask,telegram,телеграм,telegram bot,чат-бот,website,web app,сайт,лендинг,automation,автоматизация,parser,парсер,парсинг,scraping,api integration,интеграция api
NEGATIVE_KEYWORDS=casino,adult,essay,rewrite,forex,betting
STRICT_TOPIC_FILTER=true

# Optional profile memory for proposal generation
FREELANCER_PROFILE=Python-разработчик. Делаю Telegram-ботов, парсеры, интеграции API, AI-автоматизацию.
PORTFOLIO_URLS=https://github.com/yourname,https://t.me/yourchannel

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000
PLAYWRIGHT_FEED_TIMEOUT_MS=15000
PLAYWRIGHT_CARDS_WAIT_TIMEOUT_MS=5000
PLAYWRIGHT_STEALTH_ENABLED=true
PLAYWRIGHT_DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
PLAYWRIGHT_LOCALE=ru-RU
PLAYWRIGHT_TIMEZONE_ID=Europe/Moscow
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=720
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
PLAYWRIGHT_ANTI_BOT_JITTER_MIN_MS=250
PLAYWRIGHT_ANTI_BOT_JITTER_MAX_MS=1200
PLAYWRIGHT_BLOCK_RESOURCES=true
PLAYWRIGHT_BLOCK_RESOURCE_TYPES=image,media,font
PLAYWRIGHT_REUSE_BROWSER=false
PLAYWRIGHT_BROWSER_RECYCLE_CONTEXTS=24
PLAYWRIGHT_BROWSER_MAX_AGE_MINUTES=30
PLAYWRIGHT_LAUNCH_ARGS=
SESSIONS_DIR=./state
DB_BACKUP_ENABLED=false
DB_BACKUP_DIR=./backups
DB_BACKUP_HOUR_LOCAL=4
DB_BACKUP_RETENTION_DAYS=14
EVENTS_CLEANUP_ENABLED=true
EVENTS_CLEANUP_HOUR_LOCAL=5
EVENTS_RETENTION_DAYS=30
EVENTS_MAX_ROWS=5000
LEADS_CLEANUP_ENABLED=true
LEADS_CLEANUP_HOUR_LOCAL=6
LEADS_RETENTION_DAYS=45
STALE_PENDING_ALERT_ENABLED=true
STALE_PENDING_ALERT_THRESHOLD=40
STALE_PENDING_ALERT_DAYS=45
DELIVERY_HEALTH_ALERT_ENABLED=true
DELIVERY_HEALTH_WINDOW_MINUTES=30
DELIVERY_HEALTH_ALERT_THRESHOLD=0.4
DELIVERY_HEALTH_ALERT_MIN_ATTEMPTS=10
DELIVERY_HEALTH_ALERT_COOLDOWN_MINUTES=30
DELIVERY_STREAK_ALERT_ENABLED=true
DELIVERY_STREAK_ALERT_THRESHOLD=8
TELEGRAM_HEARTBEAT_ENABLED=true
TELEGRAM_HEARTBEAT_INTERVAL_MINUTES=15
TELEGRAM_HEARTBEAT_FAIL_THRESHOLD=3
PENDING_REANIMATE_ENABLED=true
PENDING_REANIMATE_INTERVAL_MINUTES=30
PENDING_REANIMATE_MAX_RUNS_PER_DAY=12
PENDING_REANIMATE_MIN_LOCKED=3
PENDING_QUEUE_ALERT_ENABLED=true
PENDING_QUEUE_ALERT_THRESHOLD=60
NO_NEW_LEADS_ALERT_ENABLED=true
NO_NEW_LEADS_ALERT_MINUTES=45
WORKER_STALL_ALERT_ENABLED=true
WORKER_STALL_ALERT_MINUTES=12
PLATFORM_FAILOVER_ENABLED=true
PLATFORM_FAILOVER_ERROR_STREAK=3
PLATFORM_FAILOVER_SKIP_MINUTES=30
PLATFORM_FAILOVER_SLA_ALERT_ENABLED=true
PLATFORM_FAILOVER_SLA_THRESHOLD=2

# Platform toggles
ENABLE_FLRU=true
ENABLE_FREELANCE_RU=true
ENABLE_KWORK=true
ENABLE_WORKZILLA=true
ENABLE_YOUDO=true
ENABLE_YANDEX_USLUGI=true
ENABLE_FREELANCEJOB=true
