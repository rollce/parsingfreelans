# Core
APP_ENV=dev
DATABASE_PATH=./data/freelans.db
POLL_INTERVAL_SECONDS=180
MIN_SCORE_TO_APPLY=0.45
MAX_LEADS_PER_PLATFORM=40
MAX_APPLIES_PER_CYCLE=30
AUTO_APPLY=false

# Telegram
TELEGRAM_BOT_TOKEN=put_your_token_here
TELEGRAM_CHAT_ID=put_your_chat_id_here
TELEGRAM_CONTROL_ENABLED=true
TELEGRAM_CONTROL_POLL_TIMEOUT=20

# LLM
LLM_PROVIDER=openrouter

# OpenRouter (recommended)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=freelans-bot

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Matching
TARGET_LANGUAGES=ru,en
KEYWORDS=telegram bot,chatbot,ai automation,python,парсинг,бот,интеграции
NEGATIVE_KEYWORDS=casino,adult,essay,rewrite,forex,betting

# Optional profile memory for proposal generation
FREELANCER_PROFILE=Python-разработчик. Делаю Telegram-ботов, парсеры, интеграции API, AI-автоматизацию.
PORTFOLIO_URLS=https://github.com/yourname,https://t.me/yourchannel

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000
SESSIONS_DIR=./state

# Platform toggles
ENABLE_FLRU=true
ENABLE_FREELANCE_RU=true
ENABLE_KWORK=true
ENABLE_WORKZILLA=true
ENABLE_YOUDO=true
ENABLE_YANDEX_USLUGI=true
ENABLE_FREELANCEJOB=true
